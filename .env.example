# Local development environment for the sync jobs (GeoDirectory places + Yodel
# events). Copy to `.env` (gitignored) and fill in. In CI these come from GitHub
# Secrets.

# --- Yodel events sync (events_sync.py) ---
# The Yodel widget JSON export URL. The feed is unauthenticated (the access
# token is baked into the URL path), so treat the ENTIRE URL as a secret.
YODEL_FEED_URL=https://my.yodel.today/api/v3/export/widget/json_v1/YOUR-FEED-TOKEN

# --- GeoDirectory places sync (sync.py) ---
# GeoDirectory source site (no trailing slash needed; it's stripped anyway).
# Point at a staging host pre-launch, the production site after.
GEODIR_BASE_URL=https://connecthappyvalley.com

# HTTP Basic Auth for a staging .htpasswd, as "username:password".
# Leave UNSET / delete this line once the site is public and basic auth is removed.
# GEODIR_BASIC_AUTH=username:password

# Supabase target.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# service_role key (NOT the anon key) — Settings → API → service_role. Secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
